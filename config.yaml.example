# Sisyphus external configuration template.
# Copy this file to ~/.config/sisyphus/config.yaml (Linux/macOS)
# or %APPDATA%/sisyphus/config.yaml (Windows),
# or set SISYPHUS_CONFIG to point to your local config file.

llm:
  provider: deepseek
  model: deepseek-v4-pro
  base_url: https://api.deepseek.com
  api_key: ${DEEPSEEK_API_KEY}
  max_tokens: 8192
  temperature: 0.0
  timeout: 120

agent:
  max_steps: 50
  max_concurrent: 4

queue:
  size: 256
  workers: 2

memory:
  max_messages: 100
  max_tokens: 128000

# No skills are defined here by design.
# Use MCP servers for external capability integration.
mcp_servers:
  - name: filesystem
    enabled: true
    command: npx
    args:
      - -y
      - '@modelcontextprotocol/server-filesystem'
      - '${SISYPHUS_WORKSPACE}'
    env: {}
    timeout_seconds: 30

  - name: github
    enabled: false
    command: npx
    args:
      - -y
      - '@modelcontextprotocol/server-github'
    env:
      GITHUB_TOKEN: ${GITHUB_TOKEN}
    timeout_seconds: 30

tools:
  enabled:
    - bash
    - read_file
    - write_file
    - edit_file
    - list_files
    - search
  bash:
    timeout_seconds: 10
  web_search:
    provider: tavily
    endpoint: https://api.tavily.com/search
    api_key: ${TAVILY_API_KEY}
    timeout_seconds: 15
    default_max_results: 5
    max_results_limit: 10

log_level: info
